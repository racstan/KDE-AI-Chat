<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
                          http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
  <kcfgfile name=""/>
  <group name="General">
    <entry name="provider" type="String">
      <default>openai</default>
    </entry>

    <entry name="appDisplayName" type="String">
      <default>KDE AI Chat</default>
    </entry>

    <entry name="appearanceMode" type="Int">
      <default>0</default>
    </entry>

    <entry name="baseUrl" type="String">
      <default>https://api.openai.com/v1</default>
    </entry>
    <entry name="apiKey" type="String">
      <default></default>
    </entry>
    <entry name="model" type="String">
      <default>gpt-4o-mini</default>
    </entry>

    <entry name="anthropicApiKey" type="String">
      <default></default>
    </entry>
    <entry name="anthropicModel" type="String">
      <default>claude-3-5-sonnet-latest</default>
    </entry>

    <entry name="groqBaseUrl" type="String">
      <default>https://api.groq.com/openai/v1</default>
    </entry>
    <entry name="groqApiKey" type="String">
      <default></default>
    </entry>
    <entry name="groqModel" type="String">
      <default>llama-3.3-70b-versatile</default>
    </entry>

    <entry name="deepSeekBaseUrl" type="String">
      <default>https://api.deepseek.com</default>
    </entry>
    <entry name="deepSeekApiKey" type="String">
      <default></default>
    </entry>
    <entry name="deepSeekModel" type="String">
      <default>deepseek-v4-pro</default>
    </entry>

    <entry name="miniMaxBaseUrl" type="String">
      <default>https://api.minimax.io/v1</default>
    </entry>
    <entry name="miniMaxApiKey" type="String">
      <default></default>
    </entry>
    <entry name="miniMaxModel" type="String">
      <default>MiniMax-M2.7</default>
    </entry>

    <entry name="fireworksBaseUrl" type="String">
      <default>https://api.fireworks.ai/inference/v1</default>
    </entry>
    <entry name="fireworksApiKey" type="String">
      <default></default>
    </entry>
    <entry name="fireworksModel" type="String">
      <default>accounts/fireworks/models/llama-v3p3-70b-instruct</default>
    </entry>

    <entry name="googleBaseUrl" type="String">
      <default>https://generativelanguage.googleapis.com/v1beta/openai/</default>
    </entry>
    <entry name="googleApiKey" type="String">
      <default></default>
    </entry>
    <entry name="googleModel" type="String">
      <default>gemini-3-flash-preview</default>
    </entry>

    <entry name="openRouterBaseUrl" type="String">
      <default>https://openrouter.ai/api/v1</default>
    </entry>
    <entry name="openRouterApiKey" type="String">
      <default></default>
    </entry>
    <entry name="openRouterModel" type="String">
      <default>openai/gpt-4o-mini</default>
    </entry>
    <entry name="openRouterReferer" type="String">
      <default></default>
    </entry>
    <entry name="openRouterTitle" type="String">
      <default>KDE AI Chat</default>
    </entry>

    <entry name="mistralBaseUrl" type="String">
      <default>https://api.mistral.ai/v1</default>
    </entry>
    <entry name="mistralApiKey" type="String">
      <default></default>
    </entry>
    <entry name="mistralModel" type="String">
      <default>mistral-small-latest</default>
    </entry>

    <entry name="cloudflareBaseUrl" type="String">
      <default>https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/ai/v1</default>
    </entry>
    <entry name="cloudflareApiKey" type="String">
      <default></default>
    </entry>
    <entry name="cloudflareModel" type="String">
      <default>@cf/meta/llama-3.1-8b-instruct</default>
    </entry>

    <entry name="nvidiaBaseUrl" type="String">
      <default>https://integrate.api.nvidia.com/v1</default>
    </entry>
    <entry name="nvidiaApiKey" type="String">
      <default></default>
    </entry>
    <entry name="nvidiaModel" type="String">
      <default>meta/llama-3.1-70b-instruct</default>
    </entry>

    <entry name="huggingFaceBaseUrl" type="String">
      <default>https://router.huggingface.co/v1</default>
    </entry>
    <entry name="huggingFaceApiKey" type="String">
      <default></default>
    </entry>
    <entry name="huggingFaceModel" type="String">
      <default>openai/gpt-oss-120b:groq</default>
    </entry>

    <entry name="xaiBaseUrl" type="String">
      <default>https://api.x.ai/v1</default>
    </entry>
    <entry name="xaiApiKey" type="String">
      <default></default>
    </entry>
    <entry name="xaiModel" type="String">
      <default>grok-2-latest</default>
    </entry>

    <entry name="lmStudioBaseUrl" type="String">
      <default>http://localhost:1234/v1</default>
    </entry>
    <entry name="lmStudioModel" type="String">
      <default></default>
    </entry>

    <entry name="localBaseUrl" type="String">
      <default>http://localhost:11434/v1</default>
    </entry>
    <entry name="localModel" type="String">
      <default>llama3.2</default>
    </entry>

    <entry name="ollamaBaseUrl" type="String">
      <default>http://localhost:11434/v1</default>
    </entry>
    <entry name="ollamaModel" type="String">
      <default>llama3.2</default>
    </entry>

    <entry name="useOpenCode" type="Bool">
      <default>false</default>
    </entry>
    <entry name="openCodeUrl" type="String">
      <default>http://127.0.0.1:4096/v1</default>
    </entry>
    <entry name="openCodeProvider" type="String">
      <default></default>
    </entry>
    <entry name="openCodeModel" type="String">
      <default></default>
    </entry>
    <entry name="openCodeStartCommand" type="String">
      <default>nohup opencode serve --port 4096 >/tmp/kdeaichat-opencode.log 2&gt;&amp;1 &amp; echo OpenCode start command launched.</default>
    </entry>
    <entry name="openCodeStopCommand" type="String">
      <default>pkill -f opencode &gt;/dev/null 2&gt;&amp;1 &amp;&amp; echo OpenCode stop command launched. || echo No OpenCode process matched.</default>
    </entry>

    <entry name="kwalletName" type="String">
      <default>kdeaichatwallet</default>
    </entry>

    <entry name="useKWallet" type="Bool">
      <default>false</default>
    </entry>

    <entry name="systemPrompt" type="String">
      <default>You are KDE AI Chat, a precise and helpful assistant. Give accurate answers, ask clarifying questions when context is missing, and clearly state uncertainty instead of inventing facts.</default>
    </entry>

    <entry name="chatSessionsJson" type="String">
      <default>[]</default>
    </entry>
    <entry name="lastSessionId" type="String">
      <default></default>
    </entry>
      <entry name="customPopupWidth" type="Int">
      <default>760</default>
    </entry>
    <entry name="customPopupHeight" type="Int">
      <default>760</default>
    </entry>
    <entry name="playNotificationSound" type="Bool">
      <default>true</default>
    </entry>
  </group>
</kcfg>
