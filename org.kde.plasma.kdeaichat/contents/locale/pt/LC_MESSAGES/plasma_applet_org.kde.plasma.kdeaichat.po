msgstr "Grave 5 segundos"

#: contents/ui/ConfigVoice.qml:887
msgid ""
"<b>Test STT:</b> Records five seconds, transcribes it, and shows the text "
"below."
msgstr ""
"<b>Teste STT:</b> grava cinco segundos, transcreve e mostra o texto abaixo."

#: contents/ui/ConfigVoice.qml:892
msgid "Transcript:"
msgstr "Transcrição:"

#: contents/ui/ConfigVoice.qml:901
msgid "Test TTS:"
msgstr "Teste TTS:"

#: contents/ui/ConfigVoice.qml:907
msgid "Speak"
msgstr "Falar"

#: contents/ui/ConfigVoice.qml:919
msgid "Voice setup is ready."
msgstr "A configuração de voz está pronta."

#: contents/ui/ConfigVoice.qml:939
msgid ""
"<b>Test TTS:</b> Speaks a short sentence with the selected TTS folder and "
"voice name."
msgstr ""
"<b>Testar TTS:</b> Fala uma frase curta com a pasta TTS selecionada e o nome"
" de voz."

#: contents/ui/ConfigVoice.qml:944
msgid "TTS result:"
msgstr "Resultado TTS:"

#: contents/ui/ConfigVoice.qml:953
msgid "Engine folder:"
msgstr "Pasta do motor:"

#: contents/ui/ConfigVoice.qml:976
msgid ""
"<b>Engine folder:</b> Stores the small Python environment used to run your "
"selected models. This is not a model folder."
msgstr ""
"<b>Pasta Engine:</b> Armazena o pequeno ambiente Python usado para executar "
"seus modelos selecionados. Esta não é uma pasta de modelo."
