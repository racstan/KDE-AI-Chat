#: contents/ui/ConfigVoice.qml:939
msgid ""
"<b>Test TTS:</b> Speaks a short sentence with the selected TTS folder and "
"voice name."
msgstr ""
"<b>Prueba TTS:</b> pronuncia una frase corta con la carpeta TTS seleccionada"
" y el nombre de la voz."

#: contents/ui/ConfigVoice.qml:944
