#: contents/ui/ConfigVoice.qml:655
msgid ""
"<b>Auto read:</b> Turn this on only if every AI response should be spoken "
"automatically."
msgstr ""
"<b>Lecture automatique :</b> activez cette option uniquement si chaque "
"réponse de l'IA doit être prononcée automatiquement."

