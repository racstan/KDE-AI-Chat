#: contents/ui/ConfigVoice.qml:634
msgid ""
"<b>Voice name:</b> Use the voice id expected by the selected TTS model. If "
"the model has voice files, use the file name without its extension."
msgstr ""
"<b>Nom de la voix :</b> utilisez l'identifiant vocal attendu par le modèle "
"TTS sélectionné. Si le modèle possède des fichiers vocaux, utilisez le nom "
"du fichier sans son extension."

