msgstr "Sélectionnez un dossier de modèle TTS"

#: contents/ui/ConfigVoice.qml:608
msgid ""
"<b>TTS folder:</b> Pick the folder that contains your text-to-speech model "
"files."
msgstr ""
"<b>Dossier TTS :</b> choisissez le dossier qui contient vos fichiers de "
"modèle de synthèse vocale."

