msgid "STT folder:"
msgstr "Dossier STT :"

#: contents/ui/ConfigVoice.qml:479
msgid "Select an STT model folder"
msgstr "Sélectionnez un dossier de modèle STT"

#: contents/ui/ConfigVoice.qml:488 contents/ui/ConfigVoice.qml:595
msgid "Browse"
msgstr "Parcourir"

#: contents/ui/ConfigVoice.qml:501
msgid ""
"<b>STT folder:</b> Pick the folder that contains your speech-to-text model "
"files."
msgstr ""
"<b>Dossier STT :</b> choisissez le dossier qui contient vos fichiers de "
"modèle de synthèse vocale."

