msgstr "japonais"

#: contents/ui/ConfigVoice.qml:523
msgid "Korean"
msgstr "coréen"

#: contents/ui/ConfigVoice.qml:524
msgid "Chinese"
msgstr "Chinois"

#: contents/ui/ConfigVoice.qml:548
msgid ""
"<b>Language:</b> Use Auto for multilingual models. Use English for English-"
"only models."
msgstr ""
"<b>Langue :</b> utilisez Auto pour les modèles multilingues. Utilisez "
"l'anglais pour les modèles uniquement en anglais."

#: contents/ui/ConfigVoice.qml:554
msgid "Read aloud:"
msgstr "Lire à haute voix :"

#: contents/ui/ConfigVoice.qml:572
msgid ""
"<b>Read aloud:</b> Enables text-to-speech. Leave it off if you only want "
"microphone input."
msgstr ""
"<b>Lire à haute voix :</b> active la synthèse vocale. Laissez-le désactivé "
"si vous souhaitez uniquement une entrée microphone."

