msgid "Select a TTS model folder"
msgstr "Wählen Sie einen TTS-Modellordner aus"

#: contents/ui/ConfigVoice.qml:608
msgid ""
"<b>TTS folder:</b> Pick the folder that contains your text-to-speech model "
"files."
msgstr ""
"<b>TTS-Ordner:</b> Wählen Sie den Ordner aus, der Ihre Text-zu-Sprache-"
"Modelldateien enthält."

#: contents/ui/ConfigVoice.qml:613
msgid "Voice name:"
msgstr "Sprachname:"

#: contents/ui/ConfigVoice.qml:621
msgid "Voice id or name"
msgstr "Sprach-ID oder Name"

#: contents/ui/ConfigVoice.qml:634
msgid ""
"<b>Voice name:</b> Use the voice id expected by the selected TTS model. If "
"the model has voice files, use the file name without its extension."
msgstr ""
"<b>Sprachname:</b> Verwenden Sie die vom ausgewählten TTS-Modell erwartete "
"Sprach-ID. Wenn das Modell über Sprachdateien verfügt, verwenden Sie den "
"Dateinamen ohne Erweiterung."

